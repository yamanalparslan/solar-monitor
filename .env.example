# ============================================================
# SOLAR MONITOR - ORTAM DEĞİŞKENLERİ
# Bu dosyayı ".env" olarak kopyalayın ve değerleri düzenleyin.
# ============================================================

# --- Modbus Bağlantısı ---
MODBUS_IP=10.35.14.10
MODBUS_PORT=502
SLAVE_IDS=1,2,3

# --- Zamanlayıcı ---
REFRESH_RATE=60

# --- Register Adresleri ---
GUC_ADDR=70
VOLT_ADDR=71
AKIM_ADDR=72
ISI_ADDR=73

# --- Çarpan Katsayıları ---
GUC_SCALE=1.0
VOLT_SCALE=0.1
AKIM_SCALE=0.1
ISI_SCALE=1.0

# --- Veritabanı ---
DB_NAME=solar_log.db

# --- Loglama ---
LOG_LEVEL=INFO

# --- Authentication ---
AUTH_ENABLED=true
AUTH_USERNAME=admin
# Varsayılan şifre: solar2026
# Yeni hash oluşturmak için: python auth.py yeni_sifre
AUTH_PASSWORD_HASH=

# --- Telegram Bildirimleri ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Webhook Bildirimleri ---
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# --- Alarm Ayarları ---
# Aynı alarm kaç dakika içinde tekrar gönderilmesin
ALARM_COOLDOWN_MIN=30

# --- Anomali Tespiti ---
ANOMALY_POWER_DROP_PCT=50
ANOMALY_VOLT_MIN=150
ANOMALY_VOLT_MAX=260
ANOMALY_TEMP_MAX=75
ANOMALY_OFFLINE_MIN=5
ANOMALY_FLEET_DROP_PCT=40
ANOMALY_COOLDOWN_MIN=10

# --- RBAC (Rol Bazlı Yetki) ---
# Format: kullanici1:admin,kullanici2:operator,kullanici3:viewer
USER_ROLES=admin:admin

# --- REST API ---
API_PORT=8503

# --- Prometheus ---
PROMETHEUS_PORT=9100
PROMETHEUS_SCRAPE_INTERVAL=10

# --- Healthcheck ---
HEALTH_PORT=8502

# --- Yedekleme ---
# Maksimum yedek sayısı (eskiler silinir)
BACKUP_MAX_COUNT=10

# --- MQTT (IoT) ---
MQTT_ENABLED=true
MQTT_HOST=solar_mosquitto
MQTT_PORT=1883

# ============================================================
# CRM ENTEGRASYON AYARLARI (GÖMME / EMBED)
# ============================================================

# --- CRM Bağlantı Bilgileri ---
# CRM sisteminin base URL'i (Örn: https://crm.sirketiniz.com)
CRM_BASE_URL=xxxxx

# CRM API anahtarı veya token (CRM yöneticinizden alın)
CRM_API_KEY=xxxxx

# CRM API secret (varsa, bazı CRM'ler bunu ister)
CRM_API_SECRET=xxxxx

# --- CRM Kullanıcı/Tenant Bilgileri ---
# CRM'deki şirket/tenant ID'niz
CRM_TENANT_ID=xxxxx

# CRM'deki kullanıcı adı (entegrasyon kullanıcısı)
CRM_USERNAME=xxxxx

# CRM'deki şifre veya service account token
CRM_PASSWORD=xxxxx

# --- Gömme (Embed) Ayarları ---
# CRM'nin Solar Monitor'ü gömeceği izin verilen origin (CORS)
# Örn: https://crm.sirketiniz.com veya * (tümüne izin, güvenli değil)
CRM_ALLOWED_ORIGIN=xxxxx

# Solar Monitor'ün CRM içinde erişileceği harici URL
# Örn: http://10.35.14.5:8501 veya https://solar.sirketiniz.com
SOLAR_MONITOR_EXTERNAL_URL=xxxxx

# --- CRM Webhook (Opsiyonel) ---
# Alarm/bildirim olduğunda CRM'ye webhook göndermek isterseniz
CRM_WEBHOOK_URL=xxxxx
CRM_WEBHOOK_SECRET=xxxxx

# --- Gömme Modu ---
# true = Streamlit sidebar ve menüler gizlenir (temiz iframe görünümü)
# false = Normal görünüm (tam ekran kullanım)
CRM_EMBED_MODE=true
